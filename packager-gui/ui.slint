// packager-gui/ui.slint
// SetupWeaver Packager — the developer-facing tool that turns a manifest into a
// self-contained setup.exe.
//
// This is a full visual redesign. The Rust <-> Slint contract is preserved
// verbatim so packager-gui/src/main.rs keeps compiling unchanged:
//   - 4 structs: FileEntryData, ShortcutEntryData, RegistryEntryData, RunEntryData
//   - 24 in-out properties (app_*, default_dir, add_to_path,
//     create_desktop_shortcut, require_admin, theme_index, accent_color,
//     welcome_text, license_file, file/shortcut/registry/run_entries,
//     stub_path, stub_admin_path, output_path, config_path, build_progress,
//     build_status, build_log, building, current_page)
//   - 33 callbacks (nav_clicked, browse_*, save/load_config, build_installer,
//     add/remove/..._changed for the 4 entry types, generate_toml)
//   - 8 pages, indices 0..7

import {
    LineEdit, TextEdit, CheckBox, ComboBox,
    ScrollView, Spinner,
} from "std-widgets.slint";

// ──────────────────────────────────────────────────────────────────────────────
// Design tokens
// ──────────────────────────────────────────────────────────────────────────────
global Theme {
    // Surfaces
    out property <color> page-bg: #f4f5f9;
    out property <color> card-bg: #ffffff;
    out property <color> card-border: #e6e8f0;
    out property <color> divider: #edeef3;
    out property <color> entry-bg: #f8f9fc;
    out property <color> entry-border: #e8eaf1;
    out property <color> input-border: #cdd2de;

    // Sidebar (dark)
    out property <brush>  sidebar-bg: @linear-gradient(180deg, #1b2236 0%, #131829 100%);
    out property <color>  sidebar-border: #262d42;
    out property <color>  sidebar-text: #e9ecf5;
    out property <color>  sidebar-text-muted: #98a0b6;
    out property <color>  sidebar-active-bg: #2b3454;
    out property <color>  sidebar-hover-bg: #232a40;
    out property <color>  sidebar-badge-bg: #2c344e;

    // Accent
    out property <color> accent: #6366f1;
    out property <color> accent-strong: #4f46e5;
    out property <color> accent-soft: #eef2ff;
    out property <color> on-accent: #ffffff;

    // Text
    out property <color> text-primary: #1b2030;
    out property <color> text-body: #3a4256;
    out property <color> text-secondary: #6b7280;
    out property <color> text-tertiary: #9aa1b1;

    // States
    out property <color> disabled-bg: #eef0f4;
    out property <color> disabled-fg: #b6bac4;
    out property <color> success: #16a34a;
    out property <color> success-bg: #ecfdf3;
    out property <color> success-border: #bbf7d0;
    out property <color> error: #dc2626;
    out property <color> error-bg: #fef2f2;
    out property <color> error-border: #fecaca;

    // Spacing scale
    out property <length> s-1: 2px;
    out property <length> s-2: 4px;
    out property <length> s-3: 8px;
    out property <length> s-4: 12px;
    out property <length> s-5: 16px;
    out property <length> s-6: 20px;
    out property <length> s-7: 24px;
    out property <length> s-8: 32px;

    // Radii
    out property <length> r-sm: 8px;
    out property <length> r-md: 12px;
    out property <length> r-lg: 16px;
}

// ──────────────────────────────────────────────────────────────────────────────
// Reusable building blocks
// ──────────────────────────────────────────────────────────────────────────────

component Card inherits Rectangle {
    in property <bool> danger: false;
    in property <bool> success: false;
    background: danger ? Theme.error-bg : (success ? Theme.success-bg : Theme.card-bg);
    border-color: danger ? Theme.error-border : (success ? Theme.success-border : Theme.card-border);
    border-width: 1px;
    border-radius: Theme.r-md;
    drop-shadow-blur: 14px;
    drop-shadow-color: #131a3010;
    drop-shadow-offset-y: 3px;
}

// A flat pill-style button used for the top bar, page actions and rows.
component Btn inherits Rectangle {
    in property <string> text: "";
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> compact: false;

    callback clicked();

    height: compact ? 32px : 38px;
    min-width: compact ? 76px : 104px;
    border-radius: Theme.r-sm;
    border-width: root.primary ? 0px : 1px;
    border-color: root.danger ? Theme.error-border : Theme.input-border;

    background: !root.enabled
        ? Theme.disabled-bg
        : root.primary
            ? (touch.pressed ? Theme.accent-strong : (touch.has-hover ? Theme.accent-strong : Theme.accent))
            : (touch.has-hover ? Theme.accent-soft : Theme.card-bg);

    animate background { duration: 110ms; }

    HorizontalLayout {
        padding-left: root.compact ? Theme.s-4 : Theme.s-5;
        padding-right: root.compact ? Theme.s-4 : Theme.s-5;
        alignment: center;

        Text {
            text: root.text;
            color: !root.enabled
                ? Theme.disabled-fg
                : root.primary
                    ? Theme.on-accent
                    : (root.danger ? Theme.error : Theme.text-body);
            font-size: root.compact ? 12px : 13px;
            font-weight: 600;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component PageTitle inherits Text {
    color: Theme.text-primary;
    font-size: 23px;
    font-weight: 800;
    wrap: word-wrap;
}

component PageSubtitle inherits Text {
    color: Theme.text-secondary;
    font-size: 13px;
    wrap: word-wrap;
}

// A small uppercase header that introduces a group of fields inside a Card.
component SectionLabel inherits Text {
    color: Theme.text-primary;
    font-size: 14px;
    font-weight: 700;
}

component FieldLabel inherits Text {
    color: Theme.text-secondary;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
}

component FieldHint inherits Text {
    color: Theme.text-tertiary;
    font-size: 12px;
    wrap: word-wrap;
}

// A labelled input row. The single @children slot is placed directly inside a
// VerticalLayout, so the input (LineEdit / ComboBox / a nested HorizontalLayout)
// stretches edge-to-edge instead of floating at its tiny preferred width.
component FieldRow inherits VerticalLayout {
    in property <string> label: "";
    in property <string> hint: "";
    in property <bool> required: false;
    spacing: 6px;

    FieldLabel {
        text: root.required ? (root.label + "  *") : root.label;
        color: root.required ? Theme.accent-strong : Theme.text-secondary;
        visible: root.label != "";
    }

    @children

    FieldHint {
        text: root.hint;
        visible: root.hint != "";
    }
}

// "No content yet" placeholder for the list pages.
component EmptyState inherits Rectangle {
    in property <string> message: "";

    height: 120px;
    border-radius: Theme.r-md;
    background: Theme.entry-bg;
    border-width: 1px;
    border-color: Theme.entry-border;

    VerticalLayout {
        alignment: center;
        spacing: Theme.s-3;
        padding: Theme.s-5;

        Rectangle {
            width: 36px;
            height: 36px;
            border-radius: 18px;
            background: Theme.accent-soft;
            horizontal-stretch: 0;

            HorizontalLayout {
                alignment: center;
                Text {
                    text: "+";
                    color: Theme.accent;
                    font-size: 22px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
        }

        Text {
            text: root.message;
            color: Theme.text-tertiary;
            font-size: 13px;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
    }
}

// One row in the left NavRail.
component NavItem inherits Rectangle {
    in property <string> label: "";
    in property <string> badge: "";
    in property <bool> active: false;

    callback clicked();

    height: 42px;
    border-radius: Theme.r-sm;
    background: root.active
        ? Theme.sidebar-active-bg
        : (touch.has-hover ? Theme.sidebar-hover-bg : transparent);
    animate background { duration: 110ms; }

    // Left accent bar for the active row.
    Rectangle {
        x: 0;
        width: 3px;
        height: 20px;
        y: (parent.height - self.height) / 2;
        border-radius: 2px;
        background: root.active ? Theme.accent : transparent;
    }

    HorizontalLayout {
        padding-left: Theme.s-4;
        padding-right: Theme.s-3;
        spacing: Theme.s-3;

        Rectangle {
            width: 24px;
            height: 24px;
            y: (parent.height - self.height) / 2;
            border-radius: 7px;
            background: root.active ? Theme.accent : Theme.sidebar-badge-bg;

            Text {
                text: root.badge;
                color: root.active ? Theme.on-accent : Theme.sidebar-text-muted;
                font-size: 12px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
        }

        Text {
            text: root.label;
            color: root.active ? Theme.sidebar-text : Theme.sidebar-text-muted;
            font-size: 13px;
            font-weight: root.active ? 700 : 500;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// A single entry card inside a list page (Files / Shortcuts / Registry / Run).
component EntryCard inherits Rectangle {
    in property <string> index_label: "";
    in property <string> title: "";
    in property <string> subtitle: "";

    callback remove_clicked();

    border-radius: Theme.r-md;
    background: Theme.entry-bg;
    border-width: 1px;
    border-color: Theme.entry-border;

    VerticalLayout {
        padding: Theme.s-5;
        spacing: Theme.s-4;

        HorizontalLayout {
            spacing: Theme.s-3;

            Rectangle {
                width: 30px;
                height: 30px;
                border-radius: 9px;
                background: Theme.accent-soft;

                Text {
                    text: root.index_label;
                    color: Theme.accent-strong;
                    font-size: 13px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: parent.width;
                    height: parent.height;
                }
            }

            VerticalLayout {
                spacing: 1px;
                horizontal-stretch: 1;
                alignment: center;

                Text {
                    text: root.title;
                    color: Theme.text-primary;
                    font-size: 13px;
                    font-weight: 700;
                }

                Text {
                    text: root.subtitle;
                    color: Theme.text-tertiary;
                    font-size: 12px;
                    visible: root.subtitle != "";
                }
            }

            Btn {
                text: "Remove";
                compact: true;
                danger: true;
                clicked => { root.remove_clicked(); }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.entry-border;
        }

        @children
    }
}

// Browse row: LineEdit + Browse button on the right.
component BrowseRow inherits HorizontalLayout {
    in-out property <string> text: "";
    in-out property <string> placeholder: "";
    in property <bool> enabled: true;
    callback browse();

    spacing: Theme.s-3;

    LineEdit {
        text <=> root.text;
        placeholder-text: root.placeholder;
        enabled: root.enabled;
        horizontal-stretch: 1;
    }

    Btn {
        text: "Browse…";
        enabled: root.enabled;
        compact: true;
        clicked => { root.browse(); }
    }
}

// ──────────────────────────────────────────────────────────────────────────────
// Data structs (must be declared before any property that references them)
// ──────────────────────────────────────────────────────────────────────────────
struct FileEntryData {
    src: string,
    dest: string,
    exclude: string,
}

struct ShortcutEntryData {
    name: string,
    target: string,
    args: string,
    icon: string,
}

struct RegistryEntryData {
    key: string,
    values: string,
}

struct RunEntryData {
    cmd: string,
    args: string,
    when_index: int,
}

// ──────────────────────────────────────────────────────────────────────────────
// List entry components
// ──────────────────────────────────────────────────────────────────────────────
component FileEntry inherits Rectangle {
    in property <string> src_text;
    in property <string> dest_text;
    in property <string> exclude_text;
    in property <int> entry_index;
    callback remove(int);
    callback src_changed(int, string);
    callback dest_changed(int, string);
    callback exclude_changed(int, string);
    callback browse_src(int);

    EntryCard {
        width: 100%;
        index_label: (root.entry_index + 1);
        title: "File rule";
        subtitle: "Copies a source pattern into the install folder";
        remove_clicked => { root.remove(root.entry_index); }

        VerticalLayout {
            spacing: Theme.s-4;

            FieldRow {
                label: "SOURCE PATTERN";
                hint: "Glob pattern relative to the source folder. Example: bin/**/*.dll";

                HorizontalLayout {
                    spacing: Theme.s-3;

                    LineEdit {
                        text: root.src_text;
                        horizontal-stretch: 1;
                        placeholder-text: "bin/**/*";
                        edited(value) => { root.src_changed(root.entry_index, value); }
                    }

                    Btn {
                        text: "Browse…";
                        compact: true;
                        clicked => { root.browse_src(root.entry_index); }
                    }
                }
            }

            HorizontalLayout {
                spacing: Theme.s-4;

                FieldRow {
                    label: "DESTINATION";
                    hint: "Folder inside the install path.";
                    horizontal-stretch: 1;

                    LineEdit {
                        text: root.dest_text;
                        placeholder-text: "{install_dir}";
                        edited(value) => { root.dest_changed(root.entry_index, value); }
                    }
                }

                FieldRow {
                    label: "EXCLUDE";
                    hint: "Comma-separated patterns to skip.";
                    horizontal-stretch: 1;

                    LineEdit {
                        text: root.exclude_text;
                        placeholder-text: "*.pdb, *.log";
                        edited(value) => { root.exclude_changed(root.entry_index, value); }
                    }
                }
            }
        }
    }
}

component ShortcutEntry inherits Rectangle {
    in property <string> shortcut_name;
    in property <string> target_text;
    in property <string> args_text;
    in property <string> icon_text;
    in property <int> entry_index;
    callback remove(int);
    callback name_changed(int, string);
    callback target_changed(int, string);
    callback args_changed(int, string);
    callback icon_changed(int, string);

    EntryCard {
        width: 100%;
        index_label: (root.entry_index + 1);
        title: "Shortcut";
        subtitle: "Start-menu or desktop launcher";
        remove_clicked => { root.remove(root.entry_index); }

        VerticalLayout {
            spacing: Theme.s-4;

            HorizontalLayout {
                spacing: Theme.s-4;

                FieldRow {
                    label: "NAME";
                    horizontal-stretch: 1;

                    LineEdit {
                        text: root.shortcut_name;
                        placeholder-text: "My App";
                        edited(value) => { root.name_changed(root.entry_index, value); }
                    }
                }

                FieldRow {
                    label: "TARGET";
                    horizontal-stretch: 2;

                    LineEdit {
                        text: root.target_text;
                        placeholder-text: "{install_dir}\\MyApp.exe";
                        edited(value) => { root.target_changed(root.entry_index, value); }
                    }
                }
            }

            HorizontalLayout {
                spacing: Theme.s-4;

                FieldRow {
                    label: "ARGUMENTS";
                    horizontal-stretch: 2;

                    LineEdit {
                        text: root.args_text;
                        placeholder-text: "--silent";
                        edited(value) => { root.args_changed(root.entry_index, value); }
                    }
                }

                FieldRow {
                    label: "ICON (OPTIONAL)";
                    horizontal-stretch: 1;

                    LineEdit {
                        text: root.icon_text;
                        placeholder-text: "path/to/icon.ico";
                        edited(value) => { root.icon_changed(root.entry_index, value); }
                    }
                }
            }
        }
    }
}

component RegistryEntry inherits Rectangle {
    in property <string> key_text;
    in property <string> values_text;
    in property <int> entry_index;
    callback remove(int);
    callback key_changed(int, string);
    callback values_changed(int, string);

    EntryCard {
        width: 100%;
        index_label: (root.entry_index + 1);
        title: "Registry key";
        subtitle: "Key path and the values written under it";
        remove_clicked => { root.remove(root.entry_index); }

        VerticalLayout {
            spacing: Theme.s-4;

            FieldRow {
                label: "KEY";
                hint: "Full path including hive. Example: HKCU\\Software\\MyApp";

                LineEdit {
                    text: root.key_text;
                    placeholder-text: "HKCU\\Software\\MyApp";
                    edited(value) => { root.key_changed(root.entry_index, value); }
                }
            }

            FieldRow {
                label: "VALUES";
                hint: "One per line as name:TYPE:data. Example: Version:REG_SZ:1.0.0. Types: REG_SZ, REG_DWORD, REG_BINARY.";

                TextEdit {
                    text: root.values_text;
                    height: 84px;
                    edited(value) => { root.values_changed(root.entry_index, value); }
                }
            }
        }
    }
}

component RunEntry inherits Rectangle {
    in property <string> cmd_text;
    in property <string> args_text;
    in property <int> when_index;
    in property <int> entry_index;
    callback remove(int);
    callback cmd_changed(int, string);
    callback args_changed(int, string);
    callback when_changed(int, int);

    EntryCard {
        width: 100%;
        index_label: (root.entry_index + 1);
        title: "Run hook";
        subtitle: "Command executed during install";
        remove_clicked => { root.remove(root.entry_index); }

        HorizontalLayout {
            spacing: Theme.s-4;

            FieldRow {
                label: "COMMAND";
                horizontal-stretch: 2;

                LineEdit {
                    text: root.cmd_text;
                    placeholder-text: "{install_dir}\\setup.exe";
                    edited(value) => { root.cmd_changed(root.entry_index, value); }
                }
            }

            FieldRow {
                label: "ARGUMENTS";
                horizontal-stretch: 2;

                LineEdit {
                    text: root.args_text;
                    placeholder-text: "--post-install";
                    edited(value) => { root.args_changed(root.entry_index, value); }
                }
            }

            FieldRow {
                label: "WHEN";
                horizontal-stretch: 1;

                ComboBox {
                    model: ["after extract", "before finish"];
                    current-index: root.when_index;
                    selected(value) => {
                        if value == "before finish" {
                            root.when_changed(root.entry_index, 1);
                        } else {
                            root.when_changed(root.entry_index, 0);
                        }
                    }
                }
            }
        }
    }
}

// Header for the list pages: a title row with a right-aligned action button,
// and the subtitle on its own line below. The title is the stretch element so
// the button keeps its natural width and stays inside the padded content area.
component ListPageHeader inherits VerticalLayout {
    in property <string> title;
    in property <string> subtitle;
    in property <string> action;
    in property <bool> action_enabled: true;
    callback action_clicked();

    spacing: 4px;

    HorizontalLayout {
        spacing: Theme.s-4;

        PageTitle {
            text: root.title;
            horizontal-stretch: 1;
        }

        Btn {
            text: root.action;
            primary: true;
            enabled: root.action_enabled;
            clicked => { root.action_clicked(); }
        }
    }

    PageSubtitle { text: root.subtitle; }
}

// ──────────────────────────────────────────────────────────────────────────────
// Main packager window
// ──────────────────────────────────────────────────────────────────────────────
export component PackagerWindow inherits Window {
    // ── Preserved contract (do not rename/remove). ──
    in-out property <string> app_name: "";
    in-out property <string> app_version: "";
    in-out property <string> app_publisher: "";
    in-out property <string> app_description: "";
    in-out property <string> app_icon: "";

    in-out property <string> default_dir: "";
    in-out property <bool> add_to_path: false;
    in-out property <bool> create_desktop_shortcut: true;
    in-out property <bool> require_admin: false;

    in-out property <int> theme_index: 2;
    in-out property <string> accent_color: "#0078d4";
    in-out property <string> welcome_text: "";
    in-out property <string> license_file: "";

    in-out property <[FileEntryData]> file_entries: [];
    in-out property <[ShortcutEntryData]> shortcut_entries: [];
    in-out property <[RegistryEntryData]> registry_entries: [];
    in-out property <[RunEntryData]> run_entries: [];

    in-out property <string> stub_path: "";
    in-out property <string> stub_admin_path: "";
    in-out property <string> output_path: "setup.exe";
    in-out property <string> config_path: "";
    in-out property <float> build_progress: 0;
    in-out property <string> build_status: "";
    in-out property <string> build_log: "";
    in-out property <bool> building: false;

    in-out property <int> current_page: 0;

    callback nav_clicked(int);
    callback browse_icon();
    callback browse_license();
    callback browse_stub();
    callback browse_stub_admin();
    callback browse_output();
    callback browse_config();
    callback save_config();
    callback load_config();
    callback build_installer();
    callback add_file_entry();
    callback remove_file_entry(int);
    callback file_src_changed(int, string);
    callback file_dest_changed(int, string);
    callback file_exclude_changed(int, string);
    callback browse_file_src(int);
    callback add_shortcut_entry();
    callback remove_shortcut_entry(int);
    callback shortcut_name_changed(int, string);
    callback shortcut_target_changed(int, string);
    callback shortcut_args_changed(int, string);
    callback shortcut_icon_changed(int, string);
    callback add_registry_entry();
    callback remove_registry_entry(int);
    callback registry_key_changed(int, string);
    callback registry_values_changed(int, string);
    callback add_run_entry();
    callback remove_run_entry(int);
    callback run_cmd_changed(int, string);
    callback run_args_changed(int, string);
    callback run_when_changed(int, int);
    callback generate_toml() -> string;

    title: "SetupWeaver Packager";
    preferred-width: 1100px;
    preferred-height: 740px;
    min-width: 720px;
    min-height: 480px;
    background: Theme.page-bg;

    // Best-effort live swatch for the accent colour. accent_color is a string
    // (round-trips to install.toml as-is), so the swatch stays pinned to the
    // theme accent while the LineEdit shows the actual hex value.
    out property <color> accent_swatch: Theme.accent;

    // Short status line shown in the top bar; tells the user which config is loaded.
    out property <string> config_caption:
        root.config_path == "" ? "No config loaded" : root.config_path;

    HorizontalLayout {
        padding: 0;
        spacing: 0;

        // ── Sidebar ──────────────────────────────────────────────────────────
        Rectangle {
            width: 232px;
            background: Theme.sidebar-bg;

            // Right hairline.
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: parent.height;
                background: Theme.sidebar-border;
            }

            VerticalLayout {
                padding-top: Theme.s-6;
                padding-bottom: Theme.s-5;
                padding-left: Theme.s-4;
                padding-right: Theme.s-4;
                spacing: Theme.s-2;

                // Brand block.
                HorizontalLayout {
                    padding-left: Theme.s-3;
                    padding-right: Theme.s-3;
                    padding-bottom: Theme.s-5;
                    spacing: Theme.s-3;

                    Rectangle {
                        width: 38px;
                        height: 38px;
                        border-radius: 11px;
                        background: @linear-gradient(135deg, #818cf8 0%, #4f46e5 100%);

                        Text {
                            text: "S";
                            color: #ffffff;
                            font-size: 20px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        spacing: 0;

                        Text {
                            text: "SetupWeaver";
                            color: Theme.sidebar-text;
                            font-size: 16px;
                            font-weight: 800;
                        }

                        Text {
                            text: "Installer Packager";
                            color: Theme.sidebar-text-muted;
                            font-size: 11px;
                            font-weight: 500;
                        }
                    }
                }

                NavItem {
                    label: "App Info";
                    badge: "1";
                    active: root.current_page == 0;
                    clicked => { root.nav_clicked(0); }
                }
                NavItem {
                    label: "Install Settings";
                    badge: "2";
                    active: root.current_page == 1;
                    clicked => { root.nav_clicked(1); }
                }
                NavItem {
                    label: "Files";
                    badge: "3";
                    active: root.current_page == 2;
                    clicked => { root.nav_clicked(2); }
                }
                NavItem {
                    label: "UI & Branding";
                    badge: "4";
                    active: root.current_page == 3;
                    clicked => { root.nav_clicked(3); }
                }
                NavItem {
                    label: "Shortcuts";
                    badge: "5";
                    active: root.current_page == 4;
                    clicked => { root.nav_clicked(4); }
                }
                NavItem {
                    label: "Registry";
                    badge: "6";
                    active: root.current_page == 5;
                    clicked => { root.nav_clicked(5); }
                }
                NavItem {
                    label: "Run Hooks";
                    badge: "7";
                    active: root.current_page == 6;
                    clicked => { root.nav_clicked(6); }
                }

                // Spring pushes Build to the bottom.
                Rectangle { vertical-stretch: 1; }

                Rectangle {
                    height: 1px;
                    background: Theme.sidebar-border;
                }
                Rectangle { height: Theme.s-3; }

                NavItem {
                    label: "Build Installer";
                    badge: "▶";
                    active: root.current_page == 7;
                    clicked => { root.nav_clicked(7); }
                }
            }
        }

        // ── Content column ────────────────────────────────────────────────────
        VerticalLayout {
            padding: 0;
            spacing: 0;
            horizontal-stretch: 1;

            // Top bar: config status + Load/Save.
            Rectangle {
                height: 60px;
                background: Theme.card-bg;

                Rectangle {
                    y: parent.height - 1px;
                    height: 1px;
                    background: Theme.card-border;
                }

                HorizontalLayout {
                    padding-left: Theme.s-7;
                    padding-right: Theme.s-7;
                    spacing: Theme.s-4;

                    VerticalLayout {
                        alignment: center;
                        spacing: 1px;
                        horizontal-stretch: 1;

                        Text {
                            text: "Configuration";
                            color: Theme.text-tertiary;
                            font-size: 11px;
                            font-weight: 700;
                            letter-spacing: 0.5px;
                        }

                        Text {
                            text: root.config_caption;
                            color: root.config_path == "" ? Theme.text-tertiary : Theme.text-body;
                            font-size: 13px;
                            font-weight: 600;
                            overflow: elide;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        HorizontalLayout {
                            spacing: Theme.s-3;

                            Btn {
                                text: "Load…";
                                compact: true;
                                enabled: !root.building;
                                clicked => { root.load_config(); }
                            }

                            Btn {
                                text: "Save…";
                                compact: true;
                                primary: true;
                                enabled: !root.building;
                                clicked => { root.save_config(); }
                            }
                        }
                    }
                }
            }

            // Main content area.
            Rectangle {
                background: Theme.page-bg;
                vertical-stretch: 1;

                VerticalLayout {
                    padding: Theme.s-7;
                    spacing: Theme.s-5;

                    // ─── Page 0: App Info ───
                    if root.current_page == 0 : VerticalLayout {
                        spacing: Theme.s-5;

                        VerticalLayout {
                            spacing: 3px;
                            PageTitle { text: "App Info"; }
                            PageSubtitle {
                                text: "These details appear on the installer's first screen and in Control Panel.";
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: Theme.s-5;

                                Card {

                                    VerticalLayout {
                                        padding: Theme.s-6;
                                        spacing: Theme.s-5;

                                        SectionLabel { text: "Basics"; }

                                        FieldRow {
                                            label: "APPLICATION NAME";
                                            hint: "The product name shown to the user. Required.";
                                            required: true;

                                            LineEdit {
                                                text <=> root.app_name;
                                                placeholder-text: "My Application";
                                            }
                                        }

                                        HorizontalLayout {
                                            spacing: Theme.s-4;

                                            FieldRow {
                                                label: "VERSION";
                                                hint: "Any version string. Required.";
                                                required: true;
                                                horizontal-stretch: 1;

                                                LineEdit {
                                                    text <=> root.app_version;
                                                    placeholder-text: "1.0.0";
                                                }
                                            }

                                            FieldRow {
                                                label: "PUBLISHER";
                                                hint: "Company or individual. Optional.";
                                                horizontal-stretch: 2;

                                                LineEdit {
                                                    text <=> root.app_publisher;
                                                    placeholder-text: "Your Company";
                                                }
                                            }
                                        }
                                    }
                                }

                                Card {

                                    VerticalLayout {
                                        padding: Theme.s-6;
                                        spacing: Theme.s-5;

                                        SectionLabel { text: "Details"; }

                                        FieldRow {
                                            label: "DESCRIPTION";
                                            hint: "A one-line summary shown below the welcome text.";

                                            LineEdit {
                                                text <=> root.app_description;
                                                placeholder-text: "A short description of the application";
                                            }
                                        }

                                        FieldRow {
                                            label: "ICON (.ICO)";
                                            hint: "Path to the .ico used for shortcuts and the installer window.";

                                            BrowseRow {
                                                text <=> root.app_icon;
                                                placeholder: "path/to/icon.ico";
                                                enabled: !root.building;
                                                browse => { root.browse_icon(); }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ─── Page 1: Install Settings ───
                    if root.current_page == 1 : VerticalLayout {
                        spacing: Theme.s-5;

                        VerticalLayout {
                            spacing: 3px;
                            PageTitle { text: "Install Settings"; }
                            PageSubtitle {
                                text: "Where the installer drops files and the behaviours the user can opt into.";
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: Theme.s-5;

                                Card {

                                    VerticalLayout {
                                        padding: Theme.s-6;
                                        spacing: Theme.s-5;

                                        SectionLabel { text: "Default location"; }

                                        FieldRow {
                                            label: "DEFAULT INSTALL DIRECTORY";
                                            hint: "Tokens: {ProgramFiles}, {AppData}, {Desktop}, {Temp}, {AppName}.";

                                            LineEdit {
                                                text <=> root.default_dir;
                                                placeholder-text: "{ProgramFiles}\\My App";
                                            }
                                        }
                                    }
                                }

                                Card {

                                    VerticalLayout {
                                        padding: Theme.s-6;
                                        spacing: Theme.s-4;

                                        SectionLabel { text: "User options"; }

                                        CheckBox {
                                            text: "Add to system PATH";
                                            checked <=> root.add_to_path;
                                        }

                                        CheckBox {
                                            text: "Create desktop shortcut";
                                            checked <=> root.create_desktop_shortcut;
                                        }

                                        CheckBox {
                                            text: "Require administrator privileges (UAC elevation)";
                                            checked <=> root.require_admin;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ─── Page 2: Files ───
                    if root.current_page == 2 : VerticalLayout {
                        spacing: Theme.s-5;

                        ListPageHeader {
                            title: "Files";
                            subtitle: "Each rule copies a source pattern to a destination inside the install folder.";
                            action: "+ Add Rule";
                            action_enabled: !root.building;
                            action_clicked => { root.add_file_entry(); }
                        }

                        Card {
                            vertical-stretch: 1;

                            ScrollView {
                                VerticalLayout {
                                    padding: Theme.s-5;
                                    spacing: Theme.s-4;

                                    if root.file_entries.length == 0 : EmptyState {
                                        message: "No file rules yet. Click \"+ Add Rule\" to copy your first batch of files into the installer.";
                                    }

                                    for entry[i] in root.file_entries : FileEntry {
                                        src_text: entry.src;
                                        dest_text: entry.dest;
                                        exclude_text: entry.exclude;
                                        entry_index: i;
                                        remove(idx) => { root.remove_file_entry(idx); }
                                        src_changed(idx, val) => { root.file_src_changed(idx, val); }
                                        dest_changed(idx, val) => { root.file_dest_changed(idx, val); }
                                        exclude_changed(idx, val) => { root.file_exclude_changed(idx, val); }
                                        browse_src(idx) => { root.browse_file_src(idx); }
                                    }
                                }
                            }
                        }
                    }

                    // ─── Page 3: UI & Branding ───
                    if root.current_page == 3 : VerticalLayout {
                        spacing: Theme.s-5;

                        VerticalLayout {
                            spacing: 3px;
                            PageTitle { text: "UI & Branding"; }
                            PageSubtitle {
                                text: "Theme, accent colour, welcome text, and an optional license.";
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: Theme.s-5;

                                Card {

                                    VerticalLayout {
                                        padding: Theme.s-6;
                                        spacing: Theme.s-5;

                                        SectionLabel { text: "Theme"; }

                                        FieldRow {
                                            label: "INSTALLED-APP THEME";
                                            hint: "Default colour scheme when the installer starts. Users can switch at runtime.";

                                            ComboBox {
                                                model: ["dark", "light", "system"];
                                                current-index <=> root.theme_index;
                                            }
                                        }

                                        FieldRow {
                                            label: "ACCENT COLOUR (HEX)";
                                            hint: "Used for primary buttons and progress bars throughout the wizard.";

                                            HorizontalLayout {
                                                spacing: Theme.s-3;

                                                LineEdit {
                                                    text <=> root.accent_color;
                                                    placeholder-text: "#0078d4";
                                                    horizontal-stretch: 1;
                                                }

                                                Rectangle {
                                                    width: 38px;
                                                    height: 38px;
                                                    border-radius: Theme.r-sm;
                                                    background: root.accent_swatch;
                                                    border-width: 1px;
                                                    border-color: Theme.card-border;
                                                }
                                            }
                                        }
                                    }
                                }

                                Card {

                                    VerticalLayout {
                                        padding: Theme.s-6;
                                        spacing: Theme.s-5;

                                        SectionLabel { text: "Welcome & license"; }

                                        FieldRow {
                                            label: "WELCOME TEXT";
                                            hint: "Shown on the installer's first screen. Plain text only.";

                                            LineEdit {
                                                text <=> root.welcome_text;
                                                placeholder-text: "Welcome to My App";
                                            }
                                        }

                                        FieldRow {
                                            label: "LICENSE FILE";
                                            hint: "Plain-text file the user reads and accepts before installing.";

                                            BrowseRow {
                                                text <=> root.license_file;
                                                placeholder: "LICENSE.txt";
                                                enabled: !root.building;
                                                browse => { root.browse_license(); }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ─── Page 4: Shortcuts ───
                    if root.current_page == 4 : VerticalLayout {
                        spacing: Theme.s-5;

                        ListPageHeader {
                            title: "Shortcuts";
                            subtitle: "Start-menu and desktop entries that launch your app with the right arguments.";
                            action: "+ Add Shortcut";
                            action_enabled: !root.building;
                            action_clicked => { root.add_shortcut_entry(); }
                        }

                        Card {
                            vertical-stretch: 1;

                            ScrollView {
                                VerticalLayout {
                                    padding: Theme.s-5;
                                    spacing: Theme.s-4;

                                    if root.shortcut_entries.length == 0 : EmptyState {
                                        message: "No shortcuts defined. Click \"+ Add Shortcut\" to create one.";
                                    }

                                    for entry[i] in root.shortcut_entries : ShortcutEntry {
                                        shortcut_name: entry.name;
                                        target_text: entry.target;
                                        args_text: entry.args;
                                        icon_text: entry.icon;
                                        entry_index: i;
                                        remove(idx) => { root.remove_shortcut_entry(idx); }
                                        name_changed(idx, val) => { root.shortcut_name_changed(idx, val); }
                                        target_changed(idx, val) => { root.shortcut_target_changed(idx, val); }
                                        args_changed(idx, val) => { root.shortcut_args_changed(idx, val); }
                                        icon_changed(idx, val) => { root.shortcut_icon_changed(idx, val); }
                                    }
                                }
                            }
                        }
                    }

                    // ─── Page 5: Registry ───
                    if root.current_page == 5 : VerticalLayout {
                        spacing: Theme.s-5;

                        ListPageHeader {
                            title: "Registry";
                            subtitle: "Windows registry keys the installer will create. Use cautiously.";
                            action: "+ Add Key";
                            action_enabled: !root.building;
                            action_clicked => { root.add_registry_entry(); }
                        }

                        Card {
                            vertical-stretch: 1;

                            ScrollView {
                                VerticalLayout {
                                    padding: Theme.s-5;
                                    spacing: Theme.s-4;

                                    if root.registry_entries.length == 0 : EmptyState {
                                        message: "No registry entries defined. Click \"+ Add Key\" to start.";
                                    }

                                    for entry[i] in root.registry_entries : RegistryEntry {
                                        key_text: entry.key;
                                        values_text: entry.values;
                                        entry_index: i;
                                        remove(idx) => { root.remove_registry_entry(idx); }
                                        key_changed(idx, val) => { root.registry_key_changed(idx, val); }
                                        values_changed(idx, val) => { root.registry_values_changed(idx, val); }
                                    }
                                }
                            }
                        }
                    }

                    // ─── Page 6: Run Hooks ───
                    if root.current_page == 6 : VerticalLayout {
                        spacing: Theme.s-5;

                        ListPageHeader {
                            title: "Run Hooks";
                            subtitle: "Custom commands run after extraction or right before the installer closes.";
                            action: "+ Add Hook";
                            action_enabled: !root.building;
                            action_clicked => { root.add_run_entry(); }
                        }

                        Card {
                            vertical-stretch: 1;

                            ScrollView {
                                VerticalLayout {
                                    padding: Theme.s-5;
                                    spacing: Theme.s-4;

                                    if root.run_entries.length == 0 : EmptyState {
                                        message: "No run hooks defined. Click \"+ Add Hook\" to add one.";
                                    }

                                    for entry[i] in root.run_entries : RunEntry {
                                        cmd_text: entry.cmd;
                                        args_text: entry.args;
                                        when_index: entry.when_index;
                                        entry_index: i;
                                        remove(idx) => { root.remove_run_entry(idx); }
                                        cmd_changed(idx, val) => { root.run_cmd_changed(idx, val); }
                                        args_changed(idx, val) => { root.run_args_changed(idx, val); }
                                        when_changed(idx, val) => { root.run_when_changed(idx, val); }
                                    }
                                }
                            }
                        }
                    }

                    // ─── Page 7: Build ───
                    if root.current_page == 7 : VerticalLayout {
                        spacing: Theme.s-5;

                        VerticalLayout {
                            spacing: 3px;
                            PageTitle { text: "Build Installer"; }
                            PageSubtitle {
                                text: "Pick the runtime stub and the output path, then build a self-contained setup.exe.";
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: Theme.s-5;

                                Card {

                                    VerticalLayout {
                                        padding: Theme.s-6;
                                        spacing: Theme.s-5;

                                        SectionLabel { text: "Inputs"; }

                                        FieldRow {
                                            label: "CONFIG FILE (INSTALL.TOML)";
                                            hint: "Save and load the manifest from this file.";

                                            BrowseRow {
                                                text <=> root.config_path;
                                                placeholder: "install.toml";
                                                enabled: !root.building;
                                                browse => { root.browse_config(); }
                                            }
                                        }

                                        FieldRow {
                                            label: "RUNTIME STUB";
                                            hint: "Path to setupweaver-runtime.exe — the engine that runs the install wizard.";

                                            BrowseRow {
                                                text <=> root.stub_path;
                                                placeholder: "setupweaver-runtime.exe";
                                                enabled: !root.building;
                                                browse => { root.browse_stub(); }
                                            }
                                        }

                                        FieldRow {
                                            label: "ADMIN RUNTIME STUB (OPTIONAL)";
                                            hint: "Path to setupweaver-runtime-admin.exe if your installer needs UAC.";

                                            BrowseRow {
                                                text <=> root.stub_admin_path;
                                                placeholder: "setupweaver-runtime-admin.exe";
                                                enabled: !root.building;
                                                browse => { root.browse_stub_admin(); }
                                            }
                                        }

                                        FieldRow {
                                            label: "OUTPUT FILE";
                                            hint: "Where to write the built installer. .exe only.";

                                            BrowseRow {
                                                text <=> root.output_path;
                                                placeholder: "setup.exe";
                                                enabled: !root.building;
                                                browse => { root.browse_output(); }
                                            }
                                        }

                                        Rectangle {
                                            height: 1px;
                                            background: Theme.divider;
                                        }

                                        HorizontalLayout {
                                            spacing: Theme.s-3;
                                            alignment: end;

                                            Btn {
                                                text: "Save Config";
                                                enabled: !root.building;
                                                clicked => { root.save_config(); }
                                            }

                                            Btn {
                                                text: root.building ? "Building…" : "Build Installer";
                                                primary: true;
                                                enabled: !root.building;
                                                clicked => { root.build_installer(); }
                                            }
                                        }
                                    }
                                }

                                // Status card: spinner + progress while building, then a
                                // green (success) or red (failure) summary.
                                if root.building || root.build_log != "" || root.build_status != "" : Card {
                                    danger: !root.building && root.build_progress < 1.0 && root.build_log != "";
                                    success: !root.building && root.build_progress >= 1.0;

                                    VerticalLayout {
                                        padding: Theme.s-6;
                                        spacing: Theme.s-4;

                                        HorizontalLayout {
                                            spacing: Theme.s-3;

                                            if root.building : Spinner {
                                                width: 18px;
                                                height: 18px;
                                                indeterminate: true;
                                            }

                                            if !root.building : Rectangle {
                                                width: 20px;
                                                height: 20px;
                                                border-radius: 10px;
                                                background: root.build_progress < 1.0 && root.build_log != ""
                                                    ? Theme.error
                                                    : Theme.success;

                                                Text {
                                                    text: root.build_progress < 1.0 && root.build_log != "" ? "!" : "✓";
                                                    color: #ffffff;
                                                    font-size: 12px;
                                                    font-weight: 800;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                    width: parent.width;
                                                    height: parent.height;
                                                }
                                            }

                                            Text {
                                                text: root.building
                                                    ? (root.build_status == "" ? "Building installer…" : root.build_status)
                                                    : (root.build_progress >= 1.0
                                                        ? "Installer built successfully"
                                                        : (root.build_status == "" ? "Build finished" : root.build_status));
                                                color: !root.building && root.build_progress < 1.0 && root.build_log != ""
                                                    ? Theme.error
                                                    : Theme.text-primary;
                                                font-size: 14px;
                                                font-weight: 700;
                                                wrap: word-wrap;
                                                vertical-alignment: center;
                                                horizontal-stretch: 1;
                                            }
                                        }

                                        if !root.building && root.build_progress >= 1.0 && root.output_path != "" : HorizontalLayout {
                                            spacing: Theme.s-2;

                                            Text {
                                                text: "Output:";
                                                color: Theme.text-secondary;
                                                font-size: 12px;
                                                font-weight: 700;
                                            }

                                            Text {
                                                text: root.output_path;
                                                color: Theme.text-primary;
                                                font-size: 12px;
                                                font-family: "Consolas, Menlo, monospace";
                                                wrap: no-wrap;
                                            }
                                        }

                                        if root.building : Rectangle {
                                            height: 8px;
                                            border-radius: 4px;
                                            background: Theme.divider;

                                            Rectangle {
                                                x: 0;
                                                width: parent.width * clamp(root.build_progress, 0, 1);
                                                height: parent.height;
                                                border-radius: 4px;
                                                background: Theme.accent;
                                            }
                                        }
                                    }
                                }

                                if root.build_log != "" : Card {

                                    VerticalLayout {
                                        padding: Theme.s-5;
                                        spacing: Theme.s-3;

                                        Text {
                                            text: "BUILD LOG";
                                            color: Theme.text-secondary;
                                            font-size: 12px;
                                            font-weight: 700;
                                            letter-spacing: 0.5px;
                                        }

                                        TextEdit {
                                            text: root.build_log;
                                            read-only: true;
                                            wrap: word-wrap;
                                            font-family: "Consolas, Menlo, monospace";
                                            font-size: 12px;
                                            height: 200px;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
